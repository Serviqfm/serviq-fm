{
  "expo": {
    "name": "Serviq FM",
    "slug": "serviqfm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.serviqfm.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.serviqfm.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#182848",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Serviq FM"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#182848"
    },
    "extra": {
      "eas": {
        "projectId": "1f2cdd5a-b7b2-4a26-bd36-70f00779e7aa"
      }
    },
    "owner": "serviqfm"
  }
}
