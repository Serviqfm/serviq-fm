# Expo project ID — get one by running `npx eas-cli init` (writes to app.json)
# or copy from https://expo.dev → your project → Project settings.
# Used by mobile/src/lib/notifications.ts to register push tokens.
EXPO_PUBLIC_PROJECT_ID=

# Supabase credentials are currently hardcoded in mobile/src/lib/supabase.ts.
# If you refactor to read from env, uncomment and fill these in.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
